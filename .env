# Server settings
DEBUG=false

# Rate limiting
MAX_CONCURRENT_SESSIONS=35
MAX_REQUESTS_PER_MINUTE=10
SESSION_TIMEOUT_MINUTES=30

# Frontend URL for CORS (production)
FRONTEND_URL=https://scraper.pgdev.com.br

# Cache persistence
CACHE_DB_PATH=/app/data/scrape_cache.db

# Cost control - max scrapes per session
MAX_SCRAPES_PER_SESSION=5

# Default API Keys (optional - users provide their own)
# DEFAULT_OPENAI_API_KEY=sk-...
# DEFAULT_GROQ_API_KEY=gsk_...
