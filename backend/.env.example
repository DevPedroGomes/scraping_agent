# Server settings
DEBUG=false

# Rate limiting
MAX_CONCURRENT_SESSIONS=35
MAX_REQUESTS_PER_MINUTE=10
SESSION_TIMEOUT_MINUTES=30

# Frontend URL for CORS (required in production)
# Set this to your deployed frontend URL
FRONTEND_URL=http://localhost:3000

# Default OpenAI API Key (optional - for demo purposes)
# If set, users don't need to provide their own key
# DEFAULT_OPENAI_API_KEY=sk-...
