# Server settings
DEBUG=false

# Rate limiting
MAX_CONCURRENT_SESSIONS=35
MAX_REQUESTS_PER_MINUTE=10
SESSION_TIMEOUT_MINUTES=30

# Frontend URL for CORS (required in production)
# Set this to your deployed frontend URL
FRONTEND_URL=http://localhost:3000

# Default API Keys (optional - for demo/showcase purposes)
# DEFAULT_OPENAI_API_KEY=sk-...
# DEFAULT_GROQ_API_KEY=gsk_...

# Cache persistence
CACHE_DB_PATH=scrape_cache.db

# Cost control - max scrapes per session
MAX_SCRAPES_PER_SESSION=5
